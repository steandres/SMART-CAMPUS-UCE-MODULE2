# Required in development and production
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Keep false until JWT validation is integrated with the platform Auth Service
AUTH_ENABLED=false
JWT_SECRET=development-secret
JWT_ISSUER=smart-campus-uce
JWT_AUDIENCE=scholarship-service

# In development, keep false to start without PostgreSQL
# In Docker or production, must be true
DB_ENABLED=false

# Required when DB_ENABLED=true or NODE_ENV=production
# Use DB_HOST=postgres when running with docker compose
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=scholarship_db

# Optional database tuning
DB_SYNCHRONIZE=true
DB_LOGGING=false
