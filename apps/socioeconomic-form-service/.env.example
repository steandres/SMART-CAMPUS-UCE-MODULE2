NODE_ENV=development
PORT=3001
CORS_ORIGIN=*

# In development, keep false to start without MongoDB
# In Docker or production, must be true
MONGO_ENABLED=false

# Required when MONGO_ENABLED=true or NODE_ENV=production
# Use mongodb://mongo:27017/socioeconomic_forms when running with docker compose
MONGODB_URI=mongodb://localhost:27017/socioeconomic_forms
